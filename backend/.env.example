# ============================================
# 🔧 使用前请复制此文件为 .env 并修改配置
#    cp .env.example .env
# ============================================

# ⚠️ 必填：数据库连接地址
# 如果使用 docker compose up -d db 启动的 PostgreSQL（端口 15432），保持默认即可
# 如果使用自己安装的 PostgreSQL（默认端口 5432），请改为：
#   DATABASE_URL=postgresql+asyncpg://用户名:密码@localhost:5432/数据库名
DATABASE_URL=postgresql+asyncpg://latex_editor:latex_editor_pass@localhost:15432/latex_editor

# ⚠️ 生产环境请务必修改：JWT 签名密钥（任意随机字符串即可）
SECRET_KEY=dev-secret-change-in-production

# LaTeX 编译超时时间（秒），大文档可适当调大
COMPILE_TIMEOUT=60
